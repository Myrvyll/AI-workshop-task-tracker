generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id        String    @id @default(cuid())
  rawInput  String
  title     String
  priority  String
  deadline  DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
}
