# Copy to .env.local:  cp .env.example .env.local
# Do not commit .env.local.

# Neon — paste the connection string from the dashboard (pooling on is fine).
# sslmode=require is ok; the app normalizes require→verify-full for the pg driver.
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.neon.tech/neondb?sslmode=require"

OPENAI_API_KEY="sk-replace-with-your-real-openai-api-key"
