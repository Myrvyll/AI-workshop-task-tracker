# Copy to .env.local:  cp .env.example .env.local
# Do not commit .env.local.

# Neon — use the pooled URL for the app (host contains `-pooler`).
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooler) URL for `prisma migrate` during build. Required on Vercel if DATABASE_URL is pooled.
# In the Neon dashboard: copy the “direct” connection string (no `-pooler` in the host).
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.REGION.aws.neon.tech/neondb?sslmode=require"

OPENAI_API_KEY="sk-replace-with-your-real-openai-api-key"
